# App-managed state, not configuration. Each rewrites itself on use or on
# upgrade, so tracking them is permanent drift for no benefit.
# Comments must be on their own line here — gitignore syntax treats a trailing
# '#' as part of the pattern, not as a comment.
#
# btop.conf: version header churns on every btop upgrade
# QtProject.conf: file-dialog history + treeViewHeader blob
# pavucontrol.ini: window geometry and last-used tab
.config/btop/btop.conf
.config/QtProject.conf
.config/pavucontrol.ini

