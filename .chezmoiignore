{{- $m := index .machines .chezmoi.hostname }}

# Touchpad gestures only make sense on laptop hardware.
{{- if ne $m.role "laptop" }}
.config/libinput-gestures.conf
{{- end }}

# Domer-only: units for daemons whose binaries/configs live on this box
# (ccimgd, lnxlink, cursor agent), the USB-audio boot-race drop-ins for
# pipewire/wireplumber, sunshine's Wayland env, and the shared cargo
# target dir for wam worktrees.
{{- if ne .chezmoi.hostname "domer" }}
.config/systemd/user/ccimgd.service
.config/systemd/user/cursor-agent-worker.service
.config/systemd/user/lnxlink.service
.config/systemd/user/pipewire.service.d
.config/systemd/user/sunshine.service.d
.config/systemd/user/wireplumber.service.d
.config/fish/conf.d/wam-cargo-target.fish
{{- end }}

# .zshrc just sources the CachyOS defaults — only valid on the CachyOS boxes.
{{- if not $m.is_cachyos }}
.zshrc
{{- end }}

# Repo docs — travel with the source, never applied to $HOME.
docs
README.md

# Regenerated every boot (SSH_AGENT_PID, SSH_AUTH_SOCK); never syncable.
.config/fish/fish_variables

# App-managed state, not configuration. Each rewrites itself on use or on
# upgrade, so tracking them is permanent drift for no benefit.
# Comments must be on their own line here — gitignore syntax treats a trailing
# '#' as part of the pattern, not as a comment.
#
# btop.conf: version header churns on every btop upgrade
# QtProject.conf: file-dialog history + treeViewHeader blob
# pavucontrol.ini: window geometry and last-used tab
# easyeffectsrc: usedPresets/mostUsedPresets counters and visiblePage rewrite on
#   every launch; the sibling db/*rc plugin settings stay tracked
# monitors.xml: mutter's display layout — per-machine by nature (panel size,
#   scale, arrangement), so sharing it across hosts is actively wrong
.config/btop/btop.conf
.config/QtProject.conf
.config/pavucontrol.ini
.config/easyeffects/db/easyeffectsrc
.config/monitors.xml

# Palamedes has a heavily customized fish config with Tide, sourced helpers,
# and server-specific aliases — skip overwriting it (use_custom_config in
# .chezmoidata/machines.yaml).
{{- if $m.use_custom_config }}
.config/fish/config.fish
.config/fish/conf.d/
.config/fish/functions/
.config/fish/completions/
.config/fish/themes/
{{- end }}
