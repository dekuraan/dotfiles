{{- if eq .chezmoi.hostname "framework-13" -}}
monitor=eDP-1,2256x1504@60,0x0,1.6
{{- else if eq .chezmoi.hostname "domer" -}}
monitor=DP-3,2560x1440@240,0x0,1
{{- end }}
monitor=,preferred,auto,1

# Hand the session env to systemd and dbus before anything that might rely on
# it (portals, polkit) starts.
exec-once = systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP HYPRLAND_INSTANCE_SIGNATURE XDG_SESSION_TYPE
exec-once = dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP HYPRLAND_INSTANCE_SIGNATURE
exec-once = systemctl --user start hyprpolkitagent
exec-once = xrdb -merge ~/.Xresources

# One process per line: exec-once already backgrounds each, so chaining them
# with '&' only hid which one died.
exec-once = variety
exec-once = wayle panel start
exec-once = hypridle
# Blue-light filter.
{{- if or (eq .chezmoi.hostname "framework-13") (eq .chezmoi.hostname "domer") }}
# sunsetr computes solar times from the coordinates in sunsetr.toml and drives
# hyprsunset, which is what wayle's module reads and toggles.
#
# Start sunsetr ONLY -- do not add 'exec-once = hyprsunset'. With
# backend = "hyprsunset" sunsetr spawns and owns that process itself, and it
# refuses to start at all if it finds an hyprsunset it didn't launch.
#
# exec-once rather than the shipped sunsetr.service: that unit is
# WantedBy/Requires graphical-session.target, which never activates in this
# session (hyprland is started directly, not via uwsm), so enabling it would
# be a silent no-op.
exec-once = sunsetr
{{- else }}
# gammastep elsewhere: sunsetr and hyprsunset aren't installed there. Falls
# Church; there's no geoclue provider to infer the location from.
exec-once = gammastep -l 38.8823:-77.1711
{{- end }}

source=~/.config/hypr/mocha.conf

# Set programs that you use
$terminal = ghostty
$fileManager = nautilus
$menu = fuzzel
$runMenu = fuzzel
$clipboard = rofi -modi "clipboard:greenclip print" -show clipboard -run-command '{cmd}'
$calc =  rofi -show calc -modi calc -no-show-match -no-sort
$windowMenu = rofi -show window
$browser = firefox
$lock = hyprlock


# Some default env vars.
env = XCURSOR_THEME, Catppucin-Mocha-Dark
env = XCURSOR_SIZE,24
env = QT_QPA_PLATFORMTHEME,qt5ct # change to qt6ct if you have that
env = QT_QPA_PLATFORM,wayland
env = MOZ_ENABLE_WAYLAND,1
env = SUDO_ASKPASS,/home/gideon/.local/bin/sudo-askpass

# For all categories, see https://wiki.hyprland.org/Configuring/Variables/
input {
    kb_layout = us
    kb_variant =
    kb_model =
    kb_options =ctrl:nocaps
    kb_rules =

    follow_mouse = 1

{{- if eq .chezmoi.hostname "framework-13" }}
    touchpad {
        natural_scroll = yes
    }
{{- end }}

    sensitivity = 0 # -1.0 to 1.0, 0 means no modification.
}

general {
    # See https://wiki.hyprland.org/Configuring/Variables/ for more

    gaps_in = 2
    gaps_out = 2
    border_size = 0
    col.active_border = $sapphire
    col.inactive_border = $text

    layout = dwindle

    # Please see https://wiki.hyprland.org/Configuring/Tearing/ before you turn this on
{{- if eq .chezmoi.hostname "domer" }}
    allow_tearing = true # capability only; tearing needs a per-window `immediate` rule (see below)
{{- else }}
    allow_tearing = false
{{- end }}
}

decoration {
    # See https://wiki.hyprland.org/Configuring/Variables/ for more
    active_opacity = 1.0          # Fully opaque when focused
    rounding = 10

    blur {
        enabled = false
        size = 7
        passes = 3
    }

    shadow {
        enabled = no
        range = 4
        render_power = 3
        color = rgba(26, 26, 26, 238)
    }
}

animations {
    enabled = yes

    # Some default animations, see https://wiki.hyprland.org/Configuring/Animations/ for more

    bezier = myBezier, 0.05, 0.9, 0.1, 1.05

    animation = windows, 2, 7, myBezier
    animation = windowsOut, 2, 7, default, popin 80%
    animation = border, 1, 10, default
    animation = borderangle, 1, 8, default
    animation = fade, 2, 7, default
    animation = workspaces, 2, 6, default
}

dwindle {
    # See https://wiki.hyprland.org/Configuring/Dwindle-Layout/ for more
    preserve_split = yes # required for layoutmsg togglesplit
}

xwayland {
    force_zero_scaling = true
}

master {
    # See https://wiki.hyprland.org/Configuring/Master-Layout/ for more
  new_status = master
}

gesture = 3, horizontal, workspace
gesture = 4, horizontal, workspace

misc {
    # See https://wiki.hyprland.org/Configuring/Variables/ for more
    force_default_wallpaper = 0 # Set to 0 or 1 to disable the anime mascot wallpapers
{{- if eq .chezmoi.hostname "domer" }}
    vrr = 1 # 0=off, 1=on, 2=fullscreen-only. FreeSync on the 240Hz M27Q X.
{{- end }}
}

cursor {
    # Native cursor hiding. Don't reach for unclutter here: it's an X11 client
    # and can't see the Wayland cursor.
    inactive_timeout = 2
}

# Example per-device config
# See https://wiki.hyprland.org/Configuring/Keywords/#per-device-input-configs for more
device {
    name = epic-mouse-v1
    sensitivity = -0.5
}

windowrule = min_size 250 250, match:class ^(Unity)$ title:^(Project Settings)$
windowrule = min_size 250 250, match:class ^(Unity)$ title:^(Preferences)$
windowrule = min_size 250 250, match:class ^(Unity)$ title:^(Package Manager)$
windowrule = center on, match:class ^(Unity)$, match:float yes
windowrule = workspace 3 silent, match:title ^(wam)$
{{- if eq .chezmoi.hostname "domer" }}

# Allow tearing (lower input latency) for fullscreen games. The Finals = steam_app_2073850.
# Find a game's class while it runs with: hyprctl clients | grep -i class
windowrule = immediate 1, match:class ^(steam_app_2073850)$
{{- end }}

$mainMod = SUPER
bind = $mainMod, RETURN, exec, $terminal
bind = $mainMod, Q, exec, ~/.config/hypr/scripts/safe_killactive.sh
bind = $mainMod, M, exit,
bind = $mainMod Shift, Enter, exec, $fileManager
bind = $mainMod, F, exec, $browser
bind = $mainMod, V, togglefloating,
bind = $mainMod Shift, F, fullscreen,
bind = $mainMod, space, layoutmsg, togglesplit
bind = $mainMod, D, exec, $runMenu
bind = , Print, exec, grimblast copy area
bind = CTRL, Print, exec, grimblast copy screen
bind = $mainMod, P, pseudo, # dwindle
bind = $mainMod SHIFT, J, layoutmsg, togglesplit # dwindle
bind = $mainMod SHIFT, X, exec,$lock
bind = CTRL, ESCAPE, exec, $terminal -e btop
bind = $mainMod, Tab, cyclenext,
bind = $mainMod, Tab, bringactivetotop,

# Move focus with mainMod + arrow keys
bind = $mainMod, left, movefocus, l
bind = $mainMod, right, movefocus, r
bind = $mainMod, up, workspace, e-1
bind = $mainMod, down, workspace, e+1

# Move focus with mainMod + vim keys
bind = $mainMod, H, movefocus, l
bind = $mainMod, L, movefocus, r
bind = $mainMod, K, movefocus, u
bind = $mainMod, J, movefocus, d

# Resize Windows
bind = $mainMod CTRL, right, resizeactive, 20 0
bind = $mainMod CTRL, left, resizeactive, -20 0
bind = $mainMod CTRL, up, resizeactive, 0 -20
bind = $mainMod CTRL, down, resizeactive, 0 20

# Swap workspaces between monitors
bind = $mainMod SHIFT, right, swapactiveworkspaces, current +1
bind = $mainMod SHIFT, left, swapactiveworkspaces, current -1

# Move window in layout stack
bind = $mainMod SHIFT, up, swapnext, prev
bind = $mainMod SHIFT, down, swapnext,

# Volume and Media Control

bind = , XF86AudioRaiseVolume, exec,pactl set-sink-volume @DEFAULT_SINK@ +10%
bind = , XF86AudioLowerVolume, exec, pactl set-sink-volume @DEFAULT_SINK@ -10%
bind = , XF86AudioMute, exec, pactl set-sink-mute @DEFAULT_SINK@ toggle
bind = , XF86AudioPlay, exec, playerctl play-pause
bind = , XF86AudioPause, exec, playerctl play-pause
bind = , XF86AudioNext, exec, playerctl next
bind = , XF86AudioPrev, exec, playerctl previous

{{- if eq .chezmoi.hostname "framework-13" }}

# Screen brightness
bind = , XF86MonBrightnessUp, exec, brightnessctl s +5%
bind = , XF86MonBrightnessDown, exec, brightnessctl s 5%-
{{- end }}

# Switch workspaces with mainMod + [0-9] (on current monitor)
bind = $mainMod, 1, focusworkspaceoncurrentmonitor, 1
bind = $mainMod, 2, focusworkspaceoncurrentmonitor, 2
bind = $mainMod, 3, focusworkspaceoncurrentmonitor, 3
bind = $mainMod, 4, focusworkspaceoncurrentmonitor, 4
bind = $mainMod, 5, focusworkspaceoncurrentmonitor, 5
bind = $mainMod, 6, focusworkspaceoncurrentmonitor, 6
bind = $mainMod, 7, focusworkspaceoncurrentmonitor, 7
bind = $mainMod, 8, focusworkspaceoncurrentmonitor, 8
bind = $mainMod, 9, focusworkspaceoncurrentmonitor, 9
bind = $mainMod, 0, focusworkspaceoncurrentmonitor, 10

# Move active window to a workspace with mainMod + SHIFT + [0-9]
bind = $mainMod SHIFT, 1, movetoworkspace, 1
bind = $mainMod SHIFT, 2, movetoworkspace, 2
bind = $mainMod SHIFT, 3, movetoworkspace, 3
bind = $mainMod SHIFT, 4, movetoworkspace, 4
bind = $mainMod SHIFT, 5, movetoworkspace, 5
bind = $mainMod SHIFT, 6, movetoworkspace, 6
bind = $mainMod SHIFT, 7, movetoworkspace, 7
bind = $mainMod SHIFT, 8, movetoworkspace, 8
bind = $mainMod SHIFT, 9, movetoworkspace, 9
bind = $mainMod SHIFT, 0, movetoworkspace, 10

# Mod TAB and Mod Shift Tab cycle through workspaces
bind = $mainMod ,TAB,workspace,e+1
bind = $mainMod SHIFT,TAB,workspace,e-1

# Example special workspace (scratchpad)

bind = $mainMod SHIFT, S, movetoworkspace, special:magic

# Scroll through existing workspaces with mainMod + scroll
bind = $mainMod, mouse_down, workspace, e+1
bind = $mainMod, mouse_up, workspace, e-1

# Move/resize windows with mainMod + LMB/RMB and dragging
bindm = $mainMod, mouse:272, movewindow
bindm = $mainMod, mouse:273, resizewindow

# Tiling mode with SUPER + T
bind = SUPER, T, settiled

# Floating mode with SUPER + S
bind = SUPER, S, setfloating

# record screen
bind = CTRL Shift, r, exec, ~/.config/hypr/scripts/start_record.sh
bind = CTRL Shift, p, exec, ~/.config/hypr/scripts/stop_record.sh

# volume control
bind = CTRL+alt, equal, exec, wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 1%+
bind = CTRL+alt, minus, exec, wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 1%-
bind = CTRL+alt, 0, exec, wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

bind = CTRL+Shift, equal, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%+
bind = CTRL+Shift, minus, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%-
bind = CTRL+Shift, 0, exec, wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle



# reboot
bind = CTRL+$mainMod+alt, R, exec, reboot

# clipboard
bind = $mainMod, X, exec, $clipboard

# calculator
bind = $mainMod, C, exec, $calc

{{- if eq .chezmoi.hostname "framework-13" }}
bindl=,switch:on:Lid Switch, exec, hyprlock & systemctl suspend-then-hibernate
{{- end }}
