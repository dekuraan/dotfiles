general {
    lock_cmd = pidof hyprlock || hyprlock
    before_sleep_cmd = loginctl lock-session
    after_sleep_cmd = hyprctl dispatch dpms on
}

listener {
    timeout = 300
    on-timeout = loginctl lock-session
}
{{- if eq .chezmoi.hostname "framework-13" }}

# Laptop only, and deliberately not shared: hyprland.conf starts hypridle on
# every host, so without this guard a desktop would drop into suspend 30s
# after locking, cutting off anything long-running and unattended.
listener {
    timeout = 330
    on-timeout = systemctl suspend-then-hibernate
}
{{- end }}
