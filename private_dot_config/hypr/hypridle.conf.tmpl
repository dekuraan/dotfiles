general {
    lock_cmd = pidof hyprlock || hyprlock
    before_sleep_cmd = loginctl lock-session
    after_sleep_cmd = hyprctl dispatch dpms on
}

listener {
    timeout = 300
    on-timeout = loginctl lock-session
}
{{- if eq (index .machines .chezmoi.hostname).role "laptop" }}

# Suspend is laptop-only: a desktop dropping into suspend 30s after locking
# would cut off anything long-running and unattended.
#
# Redundant today -- hyprland.conf only starts hypridle on laptops, so no
# other host reads this file -- but kept as the guard that has to hold if a
# second machine ever runs the daemon.
listener {
    timeout = 330
    on-timeout = systemctl suspend-then-hibernate
}
{{- end }}
