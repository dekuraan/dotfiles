[Unit]
Description=Cursor Agent Worker
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=120
StartLimitBurst=5

[Service]
Type=simple
Environment=PATH=/usr/local/bin:/usr/bin:/bin:/home/gideon/.local/bin
ExecStart=/home/gideon/.local/bin/agent worker start
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
