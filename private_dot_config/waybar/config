{
    "layer": "top",
    "position": "top",
    "height": 34,
    "margin-top": 0,
    "margin-left": 0,
    "margin-right": 0,
    "spacing": 0,

    "modules-left": [
        "hyprland/workspaces",
        "custom/weather",
        "custom/clock",
        "mpris"
    ],
    "modules-center": [
        "tray"
    ],
    "modules-right": [
        "custom/updates",
        "pulseaudio",
        "backlight",
        "network",
        "bluetooth",
        "battery",
        "memory",
        "cpu",
        "custom/notifications",
        "custom/power"
    ],

    "custom/launcher": {
        "format": "",
        "tooltip": false
    },

    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate",
        "sort-by-number": true,
        "persistent-workspaces": {
            "*": 9
        }
    },

    "custom/clock": {
        "exec": "~/.config/waybar/scripts/clock.sh",
        "return-type": "json",
        "interval": 30,
        "tooltip": true
    },

    "mpris": {
        "format": "{player_icon} {dynamic}",
        "format-paused": "{status_icon} {dynamic}",
        "player-icons": {
            "default": "β•Ε"
        },
        "status-icons": {
            "paused": "βèΗ"
        },
        "dynamic-order": ["title", "artist"],
        "dynamic-separator": " - ",
        "max-length": 30
    },

    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },

    "tray": {
        "icon-size": 18,
        "spacing": 8
    },

    "custom/weather": {
        "exec": "~/.config/hypr/scripts/weather.sh",
        "return-type": "json",
        "format": "{}",
        "markup": true,
        "interval": 600,
        "tooltip": true
    },

    "custom/updates": {
        "format": "σΑèî {}",
        "exec": "checkupdates 2>/dev/null | wc -l",
        "interval": 3600,
        "on-click": "ghostty -e yay",
        "tooltip": false
    },

    "pulseaudio": {
        "format": "{icon} {volume:3}%",
        "format-bluetooth": " {volume:3}%",
        "format-muted": "σΑùü",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "default": ["", "", ""]
        },
        "on-click": "wpctl set-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "wpctl set-volume @DEFAULT_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_SINK@ 5%-"
    },

    "backlight": {
        "format": "{icon} {percent:3}%",
        "format-icons": ["", "", "", "", "", "", "", "", ""],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-",
        "tooltip-format": "Brightness: {percent}%"
    },

    "network": {
        "interval": 5,
        "format-wifi": "{icon} {signalStrength:3}%",
        "format-ethernet": "σΑàÄ {bandwidthUpBits}  {bandwidthDownBits}",
        "format-disconnected": "σΑΛ≠ Disconnected",
        "format-icons": ["σΑΛ·", "σΑΛü", "σΑΛΔ", "σΑΛΞ", "σΑΛ®"],
        "tooltip-format-wifi": "  {essid}\nσΑ©ü  {ipaddr}/{cidr}\nσ±ëΫ  {signalStrength}% ({signaldBm} dBm)\n  {bandwidthUpBits}\n  {bandwidthDownBits}\nσΑΨ≤  {frequency} GHz",
        "tooltip-format-ethernet": "σΑàÄ  {ifname}\nσΑ©ü  {ipaddr}/{cidr}\n  {bandwidthUpBits}\n  {bandwidthDownBits}",
        "tooltip-format-disconnected": "No connection",
        "on-click": "nm-connection-editor",
        "on-click-right": "nmcli device wifi rescan && notify-send 'WiFi' 'Scanning for networks...'"
    },

    "bluetooth": {
        "format": " {status}",
        "format-connected": " {device_alias}",
        "format-disabled": "",
        "on-click": "blueman-manager",
        "tooltip-format": "{controller_alias}\t{controller_address}"
    },

    "battery": {
        "interval": 10,
        "states": {
            "full": 100,
            "good": 80,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity:3}% {time}",
        "format-time": "({H}h {m}m)",
        "format-charging": "σΑ²³ {capacity:3}% {time}",
        "format-plugged": "σΑ²³ {capacity:3}%",
        "format-full": "σΑ¹Ι Full",
        "format-icons": ["σΑ²é", "σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
        "tooltip-format": "Battery: {capacity}%\nStatus: {status}\nPower draw: {power:.1f}W\nHealth: {health}%\nCycles: {cycles}\nTime remaining: {time}",
        "on-click": "gnome-power-statistics 2>/dev/null || powerprofilesctl list"
    },

    "memory": {
        "format": " {used:4.1f}G",
        "interval": 3
    },

    "cpu": {
        "format": "σΑç¦ {usage:3}%",
        "interval": 1
    },

    "custom/notifications": {
        "format": "σΑ²ö",
        "tooltip": false,
        "on-click": "dunstctl set-paused toggle"
    },

    "custom/power": {
        "format": "βèΜ",
        "tooltip": false,
        "on-click": "~/.config/waybar/scripts/power-menu.sh"
    }
}
